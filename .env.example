# ─── Supabase ───────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── Database (Prisma) ──────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres

# ─── Anthropic (WhatsApp AI agent) ──────────────────────────
ANTHROPIC_API_KEY=sk-ant-xxxx

# ─── Mercado Pago (PIX payments) ────────────────────────────
MERCADO_PAGO_ACCESS_TOKEN=APP_USR-xxxx
MERCADO_PAGO_WEBHOOK_SECRET=your-webhook-secret

# ─── Z-API (WhatsApp) ───────────────────────────────────────
ZAPI_INSTANCE_ID=your-instance-id
ZAPI_TOKEN=your-token

# ─── Resend (transactional email) ───────────────────────────
RESEND_API_KEY=re_xxxx

# ─── n8n (workflow automation) ──────────────────────────────
N8N_WEBHOOK_URL=https://n8n.yourdomain.com/webhook/oo-travel

# ─── App ────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000
